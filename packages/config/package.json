{
  "name": "@arxhub/config",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "TOML-based config read/write and auto-rendering settings form for ArxHub plugins",
  "keywords": [
    "arxhub",
    "config",
    "toml"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./ui": "./src/ui/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build"
  },
  "dependencies": {
    "@sinclair/typebox": "catalog:shared",
    "@arxhub/core": "workspace:*",
    "@arxhub/errors": "workspace:*",
    "@arxhub/vfs": "workspace:*",
    "smol-toml": "catalog:shared"
  },
  "devDependencies": {
    "@arxhub/toolchain-tsconfig": "workspace:*",
    "@arxhub/toolchain-vite": "workspace:*",
    "@arxhub/uikit": "workspace:*",
    "vue": "catalog:client",
    "@vitejs/plugin-vue": "catalog:toolchain",
    "vue-tsc": "catalog:toolchain",
    "@types/node": "catalog:toolchain"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./ui": {
        "import": "./dist/ui/index.js",
        "types": "./dist/ui/index.d.ts"
      }
    }
  }
}
