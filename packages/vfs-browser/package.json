{
  "name": "@arxhub/vfs-browser",
  "sideEffects": false,
  "version": "0.1.0",
  "description": "Browser VFS implementation using IndexedDB",
  "keywords": [
    "arxhub",
    "vfs",
    "indexeddb",
    "browser"
  ],
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build"
  },
  "devDependencies": {
    "@arxhub/toolchain-tsconfig": "workspace:*",
    "@arxhub/toolchain-vite": "workspace:*",
    "@types/node": "catalog:toolchain"
  },
  "peerDependencies": {
    "@arxhub/core": "workspace:*",
    "@arxhub/stdlib": "workspace:*",
    "@arxhub/vfs": "workspace:*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  }
}
