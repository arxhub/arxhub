{
  "name": "@arxhub/uikit",
  "sideEffects": [
    "**/*.css"
  ],
  "version": "0.1.0",
  "description": "Vue 3 component library with Ark UI headless primitives",
  "keywords": [
    "arxhub",
    "ui",
    "components",
    "vue3",
    "ark-ui"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "",
  "type": "module",
  "exports": {
    "./core": "./src/core/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./desktop": "./src/desktop/index.ts",
    "./mobile": "./src/mobile/index.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build"
  },
  "dependencies": {
    "@ark-ui/vue": "catalog:client",
    "vue": "catalog:client"
  },
  "devDependencies": {
    "@arxhub/theme-preset": "workspace:*",
    "@arxhub/toolchain-tsconfig": "workspace:*",
    "@arxhub/toolchain-vite": "workspace:*",
    "@types/node": "catalog:toolchain",
    "type-fest": "catalog:toolchain"
  },
  "peerDependencies": {},
  "publishConfig": {
    "exports": {
      "./core": {
        "import": "./dist/core/index.js",
        "types": "./dist/core/index.d.ts"
      },
      "./hooks": {
        "import": "./dist/hooks/index.js",
        "types": "./dist/hooks/index.d.ts"
      },
      "./desktop": {
        "import": "./dist/desktop/index.js",
        "types": "./dist/desktop/index.d.ts"
      },
      "./mobile": {
        "import": "./dist/mobile/index.js",
        "types": "./dist/mobile/index.d.ts"
      }
    }
  }
}
