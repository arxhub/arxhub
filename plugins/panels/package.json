{
  "name": "@arxhub/plugin-panels",
  "sideEffects": [
    "**/*.css"
  ],
  "version": "0.1.0",
  "description": "Tiling panel system for ArxHub",
  "keywords": [
    "arxhub"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "",
  "type": "module",
  "exports": {
    "./manifest": "./src/manifest.ts",
    "./ui": "./src/ui.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "catalog:client",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "catalog:client",
    "lucide-vue-next": "catalog:client",
    "nanoid": "catalog:shared",
    "vue": "catalog:client"
  },
  "devDependencies": {
    "@arxhub/toolchain-tsconfig": "workspace:*",
    "@arxhub/toolchain-vite": "workspace:*",
    "@types/node": "catalog:toolchain",
    "type-fest": "catalog:toolchain"
  },
  "peerDependencies": {
    "@arxhub/core": "workspace:*",
    "@arxhub/errors": "workspace:*",
    "@arxhub/events": "workspace:*",
    "@arxhub/uikit": "workspace:*"
  },
  "publishConfig": {
    "exports": {
      "./manifest": {
        "import": "./dist/manifest.js",
        "types": "./dist/manifest.d.ts"
      },
      "./ui": {
        "import": "./dist/ui.js",
        "types": "./dist/ui.d.ts"
      }
    }
  }
}
